# ============================================
# MiniQuiz Environment Configuration
# ============================================
# Copy this file to .env.local and fill in the values
# ============================================

# ===== APPLICATION ENVIRONMENT =====
# Set to "development" for local dev (relaxed rate limits, dev features)
# Set to "production" for live deployment (strict limits, secure cookies)
ENVIRONMENT = development

# ===== NO AUTH MODE (FOR LOCAL TESTING) =====
# When set to "true": Skip ALL authentication, everyone is a guest
# User can access dashboard and create quizzes without login
# Default: false (full authentication required)
NO_AUTH_MODE = false

# ===== FRONTEND AUTH MODE =====
# Frontend reads VITE_* variables from .env.local
# Set VITE_NO_AUTH_MODE=true for no auth UI behavior
VITE_NO_AUTH_MODE = false

# ===== DATABASE =====
# MongoDB connection string
# Local: mongodb://localhost:27017/miniquiz
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/miniquiz?retryWrites=true&w=majority
MONGODB_URI = mongodb://localhost:27017/miniquiz

# ===== JWT AUTHENTICATION =====
# Secret key for signing JWT tokens (use a strong random string in production)
# Generate with: openssl rand -hex 32
SECRET_KEY = dev-secret-key-change-me-in-production
ALGORITHM = HS256

# ===== CLOUDFLARE TURNSTILE =====
# Get from Cloudflare dashboard: https://dash.cloudflare.com/
# Development/test keys: 1x00000000000000000000AA (bypasses verification)
VITE_CF_TURNSTILE_SITEKEY = 1x00000000000000000000AA
CF_TURNSTILE_SECRET = 1x0000000000000000000000000000000AA

# ===== EMAIL SERVICE (Maileroo) =====
# Get API key from: https://maileroo.com/
# Required for email verification, password reset, etc.
# Leave empty for development mode (email will be skipped, verification URL printed to console)
MAILEROO_API_KEY =

# ===== OAUTH - DISCORD =====
# Optional: Discord OAuth2 credentials
# Get from: https://discord.com/developers/applications
#DISCORD_CLIENT_ID =
#DISCORD_CLIENT_SECRET =
DISCORD_REDIRECT_URI = http://localhost:8000/api/user/discord/callback

# ===== OAUTH - GOOGLE =====
# Optional: Google OAuth2 credentials
# Get from: https://console.cloud.google.com/apis/credentials
#GOOGLE_CLIENT_ID =
#GOOGLE_CLIENT_SECRET =
GOOGLE_REDIRECT_URI = http://localhost:8000/api/user/google/callback

# ===== CORS / FRONTEND URLS =====
# Note: Frontend URL is configured in backend/app.py
# Add additional allowed origins here if deploying to custom domains
#FRONTEND_URL = http://localhost:5173
